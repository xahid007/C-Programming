// Online C compiler to run C program online
#include <stdio.h>

int main() 
{
  int arr[] = {1,2,56,7,0,3,1};
  int length = sizeof(arr) / sizeof(arr[0]);
  
  int min = arr[0];
  int second_min = arr[0];
  
  
  for(int i = 0; i<length; i++)
  {
      if(min > arr[i])
        min = arr[i];
  }
  
  for ( int i = 0; i<length; i++)
  {
      if(second_min >= arr[i] && arr[i] != min)
      second_min  = arr[i];
  }
  
  printf("%d and %d", min, second_min);
}